# Generated by reinhardt-cloud. Do not edit manually.
FROM rust:1.94.0-bookworm AS chef
RUN cargo install cargo-chef
WORKDIR /app
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM rust:1.94.0-bookworm AS builder
RUN cargo install cargo-chef
WORKDIR /app
COPY --from=chef /app/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json
COPY . .
RUN cargo build --release

FROM rust:1.94.0-bookworm AS wasm
RUN apt-get update && \
    apt-get install -y binaryen && \
    rm -rf /var/lib/apt/lists/*
RUN rustup target add wasm32-unknown-unknown
RUN cargo install wasm-bindgen-cli@0.2.118
WORKDIR /app
COPY . .
RUN cargo build --release --target wasm32-unknown-unknown
RUN wasm-bindgen --out-dir /wasm-dist --target web target/wasm32-unknown-unknown/release/reinhardt_cloud_dashboard.wasm && \
    wasm-opt -Oz -o /wasm-dist/optimized.wasm /wasm-dist/*.wasm

FROM debian:bookworm-slim AS runtime
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates tini libpq5 && \
    rm -rf /var/lib/apt/lists/*
RUN useradd --create-home appuser
WORKDIR /app
COPY --from=builder /app/target/release/reinhardt-cloud-dashboard /app/
COPY --from=wasm /wasm-dist /app/static/wasm/
RUN chown -R appuser:appuser /app
# Run as non-root
USER appuser
ENV RUST_LOG=info
EXPOSE 8000
ENTRYPOINT ["tini", "--", "/app/reinhardt-cloud-dashboard"]
