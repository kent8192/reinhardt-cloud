meta {
  name: 01 Register User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register/
  body: json
  auth: none
}

body:json {
  {
    "username": "newuser",
    "email": "newuser@example.com",
    "password": "securepassword123"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("should register user as inactive (requires email verification)", function() {
    const body = res.getBody();
    expect(body.success).to.eql(true);
  });
}
