meta {
  name: 01 Register User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register/
  body: json
  auth: none
}

body:json {
  {
    "username": "{{testUsername}}",
    "email": "{{testEmail}}",
    "password": "{{testPassword}}"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("should register user and return session cookie", function() {
    const setCookie = res.getHeader("set-cookie");
    expect(setCookie).to.be.a("string");
    expect(setCookie).to.include("sessionid=");
  });
}

script:post-response {
  const setCookie = res.getHeader("set-cookie") || "";
  const match = setCookie.match(/sessionid=([^;]+)/);
  if (match) {
    bru.setEnvVar("sessionId", match[1]);
  }
}
