meta {
  name: 02 Login User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login/
  body: json
  auth: none
}

body:json {
  {
    "username": "{{testUsername}}",
    "password": "{{testPassword}}"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("should login and return session cookie", function() {
    const raw = res.getHeader("set-cookie");
    const setCookie = Array.isArray(raw) ? raw.join("; ") : raw;
    expect(setCookie).to.be.a("string");
    expect(setCookie).to.include("sessionid=");

    const match = setCookie.match(/sessionid=([^;]+)/);
    if (match) {
      bru.setEnvVar("sessionId", match[1]);
    }
  });
}
