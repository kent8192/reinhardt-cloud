meta {
  name: List Deployments
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/deployments/
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200 with paginated response", function() {
    const body = res.getBody();
    expect(body).to.be.an("object");
    expect(body.items).to.be.an("array");
    expect(body.total).to.be.a("number");
    expect(body.page).to.equal(1);
    expect(body.page_size).to.be.a("number");
    expect(body.total_pages).to.be.a("number");
  });
}
